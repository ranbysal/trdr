# Copy to .env and set values for your environment.

# Runtime
FUTURES_BOT_ENV=development
FUTURES_BOT_LOG_LEVEL=INFO
FUTURES_BOT_TIMEZONE=America/New_York

# Data and execution endpoints (scaffold only)
DATA_PROVIDER=example
BROKER_PROVIDER=example

# Optional local overrides
CONFIG_DIR=./configs
DATABENTO_DATASET=GLBX.MDP3
DATABENTO_SCHEMA=ohlcv-1m
DATABENTO_STYPE_IN=continuous
DATABENTO_SYMBOLS=YM.v.0,NQ.v.0
BOT_ALERT_TAG=[TRADER-V1]
